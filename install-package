#!/data/service/hnp/bin/bash
# Enhanced R Package Installer for HarmonyOS
# Usage: ./install-package <package_source_dir> [install_dir]
#
# Installs an R package from source without requiring child processes
# (works around seccomp restriction blocking system() calls).
#
# Handles: C/C++/Fortran compilation, Makevars expansion, LinkingTo,
# pkg-config backtick expressions, Java sources, config.h generation.
#
# Uses tools:::.install_package_description to create proper Meta/package.rds
# and tools:::makeLazyLoading for lazy-load DB creation.

set -e

DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${DIR}/build"
export R_HOME_DIR="$BUILD_DIR"
export R_HOME="$BUILD_DIR"
export TMPDIR="${TMPDIR:-${BUILD_DIR}/tmp}"
mkdir -p "$TMPDIR"
export PATH="/usr/bin:/bin:/data/service/hnp/bin:$PATH"
export LD_LIBRARY_PATH="${BUILD_DIR}/lib:${LD_LIBRARY_PATH}"

# Compiler toolchain
CC="/data/service/hnp/bin/aarch64-unknown-linux-ohos-clang"
CXX="/data/service/hnp/bin/aarch64-unknown-linux-ohos-clang++"
SYSROOT="/data/service/hnp/ohos-sdk.org/ohos-sdk_26.0.0.18/ohos/native/sysroot"
FC="/storage/Users/currentUser/gfortran-harmonyos/build/gcc/gfortran"
FC_DIR="/storage/Users/currentUser/gfortran-harmonyos/build/gcc"
JAVA_HOME="/data/service/hnp/bishengjdk17.0.13_06.org/bishengjdk17.0.13_06_0.13_06"
JAVA="/data/service/hnp/bin/java"
JAVAC="/data/service/hnp/bin/javac"
JAR="/data/service/hnp/bin/jar"
JAVA_CPPFLAGS="-I${JAVA_HOME}/include -I${JAVA_HOME}/include/linux"

# R paths (inside build/)
R_INC="${BUILD_DIR}/include"
R_LIB="${BUILD_DIR}/lib"

# External system libraries (pre-built for HarmonyOS)
EXT_LIB="/storage/Users/currentUser/.local/R-deps"
EXT_INC="$EXT_LIB/include"
EXT_LD="$EXT_LIB/lib"

# R Makeconf-style variable definitions for Makevars substitution
BLAS_LIBS="-L$R_LIB -lRblas"
LAPACK_LIBS="-L$R_LIB -lRlapack"
FLIBS="-L$FC_DIR -lgfortran -lgcc_s"
C_VISIBILITY="-fvisibility=hidden"
SHLIB_OPENMP_CFLAGS="-fopenmp"
SHLIB_OPENMP_CXXFLAGS="-fopenmp"
SHLIB_OPENMP_FFLAGS="-fopenmp"
SHLIB_OPENMP_LIBS="-fopenmp"
R_DEBUG_FLAGS=""
R_DEBUG_CXXFLAGS=""
DEFS=""

# Default C++ standard
CXX_STD="-std=c++11"

if [ ! -f "${BUILD_DIR}/bin/exec/R" ]; then
    echo "Error: R not built yet. Run ./configure-R.sh && cd build && make first."
    exit 1
fi

if [ $# -lt 1 ]; then
    echo "Usage: $0 <package_source_dir> [install_dir]"
    exit 1
fi

PKG_SRC="$1"
LIB_DEST="${2:-${BUILD_DIR}/library}"

# Resolve to absolute paths
case "$PKG_SRC" in
  /*) ;;
  *) PKG_SRC="$PWD/$PKG_SRC" ;;
esac
case "$LIB_DEST" in
  /*) ;;
  *) LIB_DEST="$PWD/$LIB_DEST" ;;
esac

if [ ! -f "$PKG_SRC/DESCRIPTION" ]; then
    echo "Error: $PKG_SRC/DESCRIPTION not found"
    exit 1
fi

PKG_NAME=$(grep -E "^Package:" "$PKG_SRC/DESCRIPTION" | sed 's/Package:[[:space:]]*//')
if [ -z "$PKG_NAME" ]; then
    echo "Error: could not determine package name from DESCRIPTION"
    exit 1
fi

echo "Installing package '$PKG_NAME' from $PKG_SRC"

# ======== Step 1: Copy package source to library ========
rm -rf "$LIB_DEST/$PKG_NAME"
mkdir -p "$LIB_DEST/$PKG_NAME"
cp -r "$PKG_SRC"/* "$LIB_DEST/$PKG_NAME/"
echo "  Files copied to $LIB_DEST/$PKG_NAME"

# ======== Step 2: Promote inst/ contents to package root ========
if [ -d "$LIB_DEST/$PKG_NAME/inst" ]; then
    echo "  Promoting inst/ contents..."
    for inst_item in "$LIB_DEST/$PKG_NAME/inst/"* "$LIB_DEST/$PKG_NAME/inst/."*; do
        base_item=$(basename "$inst_item")
        [ "$base_item" = "." ] || [ "$base_item" = ".." ] && continue
        target="$LIB_DEST/$PKG_NAME/$base_item"
        if [ -e "$target" ]; then
            rm -rf "$target"
        fi
        mv "$inst_item" "$target" 2>/dev/null || true
    done
    rm -rf "$LIB_DEST/$PKG_NAME/inst"
fi

# ======== Step 3: Install DESCRIPTION metadata ========
echo "  Installing DESCRIPTION metadata..."
"$BUILD_DIR/bin/exec/R" --vanilla --no-save --no-restore -e \
  "library(tools); tools:::.install_package_description(\"$LIB_DEST/$PKG_NAME\", \"$LIB_DEST/$PKG_NAME\")" \
  2>&1 | grep -v "^$" | grep -v "^sh:" | grep -v "Warning.*which" | grep -v "During startup" | grep -v "^>"

# ======== Step 4: Check for R code ========
if [ ! -d "$LIB_DEST/$PKG_NAME/R" ] || [ -z "$(ls -A "$LIB_DEST/$PKG_NAME/R/" 2>/dev/null)" ]; then
    echo "  No R code found. Package installed (metadata only)."
    echo "Done."
    exit 0
fi

# ======== Step 5: Handle sysdata.rda ========
SYSDATA="$LIB_DEST/$PKG_NAME/R/sysdata.rda"
if [ -f "$SYSDATA" ]; then
    if xxd -l 2 "$SYSDATA" 2>/dev/null | grep -q "1f8b"; then
        echo "  Decompressing sysdata.rda..."
        mv "$SYSDATA" "${SYSDATA}.gz" && gzip -d "${SYSDATA}.gz" 2>/dev/null
        if [ ! -f "$SYSDATA" ]; then
            mv "${SYSDATA}.gz" "$SYSDATA" 2>/dev/null
        fi
    fi
fi

# ======== Step 6: Concatenate R source files ========
R_CONCAT="$LIB_DEST/$PKG_NAME/R/$PKG_NAME"
if [ ! -f "$R_CONCAT" ]; then
    echo "  Concatenating R source files..."

    # Parse Collate field from DESCRIPTION (multi-line)
    COLLATE=$(awk '
      /^Collate:/ { in_collate=1; sub(/^Collate:[ \t]*/, ""); line=$0 }
      in_collate && /^[ \t]/ { line=line " " $0 }
      in_collate && /^[A-Z]/ && !/^Collate:/ { exit }
      END { if (line) print line }
    ' "$LIB_DEST/$PKG_NAME/DESCRIPTION" | tr -d "'\"" | tr -s ' \n' ' ')

    if [ -n "$COLLATE" ]; then
        echo "  Using Collate order"
        for f in $COLLATE; do
            ff="$LIB_DEST/$PKG_NAME/R/$f"
            if [ -f "$ff" ]; then
                cat "$ff" >> "$R_CONCAT"
            fi
        done
        # Append any .R or .r files not in Collate
        for f in $(LC_COLLATE=C ls "$LIB_DEST/$PKG_NAME/R/"*.R "$LIB_DEST/$PKG_NAME/R/"*.r 2>/dev/null); do
            bf=$(basename "$f")
            case " $COLLATE " in *" $bf "*) ;; *) cat "$f" >> "$R_CONCAT" ;; esac
        done
    else
        echo "  Using alphabetical order"
        for f in $(LC_COLLATE=C ls "$LIB_DEST/$PKG_NAME/R/"*.R "$LIB_DEST/$PKG_NAME/R/"*.r 2>/dev/null); do
            cat "$f" >> "$R_CONCAT"
        done
    fi

    # Append sysdata loading code if sysdata.rda exists
    if [ -f "$SYSDATA" ]; then
        echo "" >> "$R_CONCAT"
        echo "# Load sysdata (added by install-package for HarmonyOS)" >> "$R_CONCAT"
        echo '.sysdata_env <- new.env(); load("R/sysdata.rda", envir = .sysdata_env); list2env(as.list(.sysdata_env), envir = topenv()); rm(.sysdata_env)' >> "$R_CONCAT"
    fi
fi

# ======== Step 7: Native code compilation (enhanced) ========

SRC_DIR="$LIB_DEST/$PKG_NAME/src"
LIBS_DIR="$LIB_DEST/$PKG_NAME/libs"
LOG_DIR="$DIR/compile-logs"
mkdir -p "$LOG_DIR"

# --- Helper functions ---

# Substitute Makevars $(VAR) and ${VAR} with actual values
expand_vars() {
  local s="$1"
  s="${s//'$(BLAS_LIBS)'/$BLAS_LIBS}"
  s="${s//'$(LAPACK_LIBS)'/$LAPACK_LIBS}"
  s="${s//'$(FLIBS)'/$FLIBS}"
  s="${s//'$(C_VISIBILITY)'/$C_VISIBILITY}"
  s="${s//'$(CXX_VISIBILITY)'/$C_VISIBILITY}"
  s="${s//'$(SHLIB_OPENMP_CFLAGS)'/$SHLIB_OPENMP_CFLAGS}"
  s="${s//'$(SHLIB_OPENMP_CXXFLAGS)'/$SHLIB_OPENMP_CXXFLAGS}"
  s="${s//'$(SHLIB_OPENMP_FFLAGS)'/$SHLIB_OPENMP_FFLAGS}"
  s="${s//'$(SHLIB_OPENMP_LIBS)'/$SHLIB_OPENMP_CFLAGS}"
  s="${s//'$(R_DEBUG_FLAGS)'/$R_DEBUG_FLAGS}"
  s="${s//'$(R_DEBUG_CXXFLAGS)'/$R_DEBUG_CXXFLAGS}"
  s="${s//'$(DEFS)'/$DEFS}"
  s="${s//'$(R_HOME)'/$BUILD_DIR}"
  s="${s//'$(STANC_FLAGS)'/ }"
  s="${s//'$(JPEG_CFLAGS)'/ }"
  s="${s//'$(PNG_CFLAGS)'/ }"
  s="${s//'$(JPEG_LIBS)'/ }"
  s="${s//'$(PNG_LIBS)'/ }"
  s="${s//'$(TCLTK_CFLAGS)'/ }"
  s="${s//'$(TCLTK_LIBS)'/ }"
  # Also handle ${VAR} curly brace variants
  s="${s//'${BLAS_LIBS}'/$BLAS_LIBS}"
  s="${s//'${LAPACK_LIBS}'/$LAPACK_LIBS}"
  s="${s//'${FLIBS}'/$FLIBS}"
  s="${s//'${C_VISIBILITY}'/$C_VISIBILITY}"
  s="${s//'${CXX_VISIBILITY}'/$C_VISIBILITY}"
  s="${s//'${SHLIB_OPENMP_CFLAGS}'/$SHLIB_OPENMP_CFLAGS}"
  s="${s//'${SHLIB_OPENMP_CXXFLAGS}'/$SHLIB_OPENMP_CXXFLAGS}"
  s="${s//'${SHLIB_OPENMP_FFLAGS}'/$SHLIB_OPENMP_FFLAGS}"
  s="${s//'${R_DEBUG_FLAGS}'/$R_DEBUG_FLAGS}"
  s="${s//'${R_DEBUG_CXXFLAGS}'/$R_DEBUG_CXXFLAGS}"
  s="${s//'${DEFS}'/$DEFS}"
  # Handle $(VAR=default) syntax used by R Makeconf
  s=$(echo "$s" | sed 's/\$(\([A-Z_]*\)=\([^)]*\))/\2/g')
  s=$(echo "$s" | sed 's/\${\([A-Z_]*\)=\([^}]*\)}/\2/g')
  # Handle pkg-config backtick expressions
  local bt='`'
  s=$(echo "$s" | sed "s/${bt}[^${bt}]*libpng-config[^${bt}]*${bt}/-I${EXT_INC//\//\\/}/g")
  s=$(echo "$s" | sed "s/${bt}[^${bt}]*freetype-config[^${bt}]*${bt}/-I${EXT_INC//\//\\/}/g")
  s=$(echo "$s" | sed "s/${bt}[^${bt}]*pkg-config[^${bt}]*${bt}//g")
  s=$(echo "$s" | sed "s/${bt}[^${bt}]*${bt}//g")
  # Clean up leading '/' or '}' before '-L'
  s=$(echo "$s" | sed 's|[/}]\(-L\)|\1|g')
  # Strip remaining $(...) patterns (GNU Make functions, undefined vars)
  while [[ "$s" == *'$('* ]]; do
    s=$(echo "$s" | sed 's/\$([^)]*)//g')
  done
  # Clean up orphaned parens from nested GNU Make function stripping
  s=$(echo "$s" | sed 's/)[)]*//g')
  echo "$s"
}

# Resolve relative -I, -L paths and .o files relative to source dir
resolve_relpaths() {
  local flags="$1"
  local srcdir="$2"
  local result=""
  for flag in $flags; do
    case "$flag" in
      -I/*|-I~*)  result="$result $flag" ;;
      -I../*|-I./*|-I[a-zA-Z]*)  result="$result -I$srcdir/${flag#-I}" ;;
      -L/*|-L~*)  result="$result $flag" ;;
      -L../*|-L./*|-L[a-zA-Z]*)  result="$result -L$srcdir/${flag#-L}" ;;
      *.o|*.a|*.so)
        if [ "${flag:0:1}" != "/" ]; then
          result="$result $srcdir/$flag"
        else
          result="$result $flag"
        fi ;;
      *)  result="$result $flag" ;;
    esac
  done
  echo "$result"
}

# Check if a package needs C++14
needs_cxx14() {
  local pkgdir="$1"
  grep -q "RcppArmadillo" "$pkgdir/DESCRIPTION" 2>/dev/null && return 0
  grep -q "RcppEigen" "$pkgdir/DESCRIPTION" 2>/dev/null && return 0
  grep -q "C++14\|c++14\|CXX14\|cxx14" "$pkgdir/src/Makevars" 2>/dev/null && return 0
  if ls "$pkgdir/src/"*.cpp "$pkgdir/src/"*.hpp 2>/dev/null | xargs grep -l "C++14\|c++14" 2>/dev/null; then
    return 0
  fi
  grep -q "ranger" "$pkgdir/DESCRIPTION" 2>/dev/null && return 0
  return 1
}

