}

# --- Main compilation logic ---

if [ -d "$SRC_DIR" ]; then
    compile_log="$LOG_DIR/$PKG_NAME.log"

    # Parse Makevars (with continuation line joining)
    PKG_CPPFLAGS=""; PKG_CFLAGS=""; PKG_FFLAGS=""; PKG_FCFLAGS=""
    PKG_CXXFLAGS=""; PKG_LIBS=""; OBJECTS=""
    MAKEVARS="$SRC_DIR/Makevars"
    if [ -f "$MAKEVARS" ]; then
        # Join continuation lines ending with backslash
        joined_vars=$(sed -e ':a' -e '/\\$/N; s/\\\n//; ta' "$MAKEVARS" 2>/dev/null)
        while IFS= read -r line; do
            case "$line" in
                .PHONY:*|all:*|\$*|include*) continue ;;
            esac
            line=$(echo "$line" | sed 's/^\([A-Z_0-9]*\)[[:space:]]*=[[:space:]]*/\1=/')
            case "$line" in
                PKG_CPPFLAGS=*) PKG_CPPFLAGS="${line#*=}" ;;
                PKG_CFLAGS=*)   PKG_CFLAGS="${line#*=}" ;;
                PKG_FFLAGS=*)   PKG_FFLAGS="${line#*=}" ;;
                PKG_FCFLAGS=*)  PKG_FCFLAGS="${line#*=}" ;;
                PKG_CXXFLAGS=*) PKG_CXXFLAGS="${line#*=}" ;;
                PKG_LIBS=*)     PKG_LIBS="${line#*=}" ;;
                OBJECTS=*)      OBJECTS="${line#*=}" ;;
                OBJS=*)         OBJECTS="${line#*=}" ;;
            esac
        done <<< "$joined_vars"

        # Strip backtick expressions before variable expansion
        for var in PKG_CPPFLAGS PKG_CFLAGS PKG_FFLAGS PKG_FCFLAGS PKG_CXXFLAGS PKG_LIBS; do
            val=$(sed 's/`[^`]*`//g' <<< "${!var}")
            printf -v "$var" "%s" "$val"
        done

        # Expand Makevars variables
        PKG_CPPFLAGS=$(expand_vars "$PKG_CPPFLAGS")
        PKG_CFLAGS=$(expand_vars "$PKG_CFLAGS")
        PKG_FFLAGS=$(expand_vars "$PKG_FFLAGS")
        PKG_FCFLAGS=$(expand_vars "$PKG_FCFLAGS")
        PKG_CXXFLAGS=$(expand_vars "$PKG_CXXFLAGS")
        PKG_LIBS=$(expand_vars "$PKG_LIBS")
        OBJECTS=$(expand_vars "$OBJECTS")

        # Resolve relative paths
        PKG_CPPFLAGS=$(resolve_relpaths "$PKG_CPPFLAGS" "$SRC_DIR")
        PKG_CFLAGS=$(resolve_relpaths "$PKG_CFLAGS" "$SRC_DIR")
        PKG_CXXFLAGS=$(resolve_relpaths "$PKG_CXXFLAGS" "$SRC_DIR")
        PKG_LIBS=$(resolve_relpaths "$PKG_LIBS" "$SRC_DIR")
    fi
    # Detect C++ standard (C++11/14/17)
    if needs_cxx14 "$LIB_DEST/$PKG_NAME"; then
        # Check if package needs C++17 (std::filesystem, inline static, constexpr if)
        pkg_src_dir="$LIB_DEST/$PKG_NAME/src"
        if grep -q "C++17\|c++17\|CXX17\|cxx17\|filesystem" "$pkg_src_dir/"*.cpp "$pkg_src_dir/"*.hpp "$pkg_src_dir/"*.h 2>/dev/null; then
            CXX_STD="-std=c++17"
        else
            CXX_STD="-std=c++14"
        fi
    fi

    # R_NO_REMAP to avoid Rmath.h log1p macro conflict with std::log1p in C++
    if grep -q "RcppArmadillo\|RcppEigen" "$LIB_DEST/$PKG_NAME/DESCRIPTION" 2>/dev/null; then
        PKG_CXXFLAGS="-DR_NO_REMAP -DHAVE_WORKING_LOG1P $PKG_CXXFLAGS"
    fi

    # Resolve LinkingTo
    LINKING_TO=$(awk 'BEGIN{found=0}
      /^LinkingTo:/{found=1; sub(/^LinkingTo:[[:space:]]*/,""); line=$0; next}
      found{if(/^[^[:space:]]/) exit; line=line" "$0}
      END{print line}' "$LIB_DEST/$PKG_NAME/DESCRIPTION" 2>/dev/null | \
      sed 's/([^)]*)//g' | tr ',' ' ' | tr -s ' ')
    LINKING_INCLUDES=""
    if [ -n "$LINKING_TO" ]; then
        for lpkg in $LINKING_TO; do
            lpkg=$(echo "$lpkg" | xargs)
            [ -z "$lpkg" ] && continue
            for try_path in \
                "$LIB_DEST/$lpkg/inst/include" \
                "$LIB_DEST/$lpkg/include"; do
                if [ -d "$try_path" ]; then
                    LINKING_INCLUDES="$LINKING_INCLUDES -I$try_path"
                    break
                fi
            done
        done
    fi

    # Self-include path
    for self_path in "$LIB_DEST/$PKG_NAME/inst/include" "$LIB_DEST/$PKG_NAME/include"; do
        if [ -d "$self_path" ]; then
            LINKING_INCLUDES="$LINKING_INCLUDES -I$self_path"
            break
        fi
    done

    # External library include paths
    if [ -d "$EXT_INC" ]; then
        LINKING_INCLUDES="$LINKING_INCLUDES -I$EXT_INC"
        for d in "$EXT_INC"/*/; do
            [ -d "$d" ] && LINKING_INCLUDES="$LINKING_INCLUDES -I$d"
        done
    fi

    # Add system library lib paths to PKG_LIBS
    if [ -d "$EXT_LD" ]; then
        PKG_LIBS="$PKG_LIBS -L$EXT_LD"
    fi

    # Workaround for RcppArmadillo missing generated config header
    arm_config="$LIB_DEST/RcppArmadillo/inst/include/RcppArmadillo/config/RcppArmadilloConfigGenerated.h"
    arm_config_in="$LIB_DEST/RcppArmadillo/inst/include/RcppArmadillo/config/RcppArmadilloConfigGenerated.h.in"
    if [ -f "$arm_config_in" ] && [ ! -f "$arm_config" ]; then
        echo "// Auto-generated by install-package" > "$arm_config"
        echo "#ifndef RcppArmadilloConfigGenerated_H" >> "$arm_config"
        echo "#define RcppArmadilloConfigGenerated_H" >> "$arm_config"
        echo "" >> "$arm_config"
        echo "#define ARMA_USE_OPENMP 0" >> "$arm_config"
        echo "" >> "$arm_config"
        echo "#endif" >> "$arm_config"
    fi

    # Generate config.h
    generate_config_h "$PKG_NAME" "$SRC_DIR" "$LIB_DEST/$PKG_NAME"

    # Detect native sources - search recursively (no -maxdepth 1 limit)
    c_srcs=$(find "$SRC_DIR" \( -name "*.c" \) 2>/dev/null | sort)
    cc_srcs=$(find "$SRC_DIR" \( -name "*.cc" -o -name "*.cpp" -o -name "*.cxx" \) 2>/dev/null | sort)
    f_srcs=$(find "$SRC_DIR" \( -name "*.f" -o -name "*.f90" -o -name "*.F" -o -name "*.F90" \) 2>/dev/null | sort)

    if [ -n "$c_srcs" ] || [ -n "$cc_srcs" ] || [ -n "$f_srcs" ]; then
        echo "  Compiling native code..."
        mkdir -p "$LIBS_DIR"
        BUILD_TMP=$(mktemp -p "$TMPDIR")
        rm -rf "$BUILD_TMP" && mkdir -p "$BUILD_TMP"
        all_objs=""
        compile_ok=true

        # Compile C sources
        for src in $c_srcs; do
            base=$(basename "$src")
            base_noext="${base%.*}"
            echo "    CC $base"
            if ! $CC -I"$R_INC" -I"$SRC_DIR" $LINKING_INCLUDES $JAVA_CPPFLAGS \
                 --sysroot="$SYSROOT" -fPIC -O2 -g0 $PKG_CPPFLAGS $PKG_CFLAGS \
                 -c "$src" -o "$BUILD_TMP/$base_noext.o" >> "$compile_log" 2>&1; then
                err=$(grep "fatal error" "$compile_log" | head -1)
                echo "    FAILED: $base -> ${err:-see $compile_log}"
                compile_ok=false; break
            fi
            all_objs="$all_objs $BUILD_TMP/$base_noext.o"
        done

        # Compile C++ sources
        if $compile_ok && [ -n "$cc_srcs" ]; then
            for src in $cc_srcs; do
                base=$(basename "$src")
                base_noext="${base%.*}"
                echo "    CXX $base"
                if ! $CXX -I"$R_INC" -I"$SRC_DIR" $LINKING_INCLUDES $JAVA_CPPFLAGS \
                     --sysroot="$SYSROOT" -fPIC -O2 -g0 $CXX_STD $PKG_CPPFLAGS $PKG_CXXFLAGS \
                     -c "$src" -o "$BUILD_TMP/$base_noext.o" >> "$compile_log" 2>&1; then
                    err=$(grep "fatal error" "$compile_log" | head -1)
                    echo "    FAILED: $base -> ${err:-see $compile_log}"
                    compile_ok=false; break
                fi
                all_objs="$all_objs $BUILD_TMP/$base_noext.o"
            done
        fi

        # Compile Fortran sources
        if $compile_ok && [ -n "$f_srcs" ] && [ -x "$FC" ]; then
            for src in $f_srcs; do
                base=$(basename "$src")
                base_noext="${base%.*}"
                echo "    FC $base"
                if ! $FC -B"$FC_DIR" -I"$SRC_DIR" -fPIC -O2 -g0 $PKG_FFLAGS $PKG_FCFLAGS \
                     -c "$src" -o "$BUILD_TMP/$base_noext.o" >> "$compile_log" 2>&1; then
                    err=$(grep "fatal error\|cannot execute" "$compile_log" | head -1)
                    echo "    FAILED: $base -> ${err:-see $compile_log}"
                    compile_ok=false; break
                fi
                all_objs="$all_objs $BUILD_TMP/$base_noext.o"
            done
        fi

        # Compile Java sources (for JNI packages like rJava)
        java_src_dir="$LIB_DEST/$PKG_NAME/java"
        java_inst_dir="$LIB_DEST/$PKG_NAME/inst/java"
        has_java=false
        if $compile_ok && [ -d "$java_src_dir" ]; then
            java_files=$(find "$java_src_dir" -name "*.java" 2>/dev/null)
            if [ -n "$java_files" ]; then
                echo "    JAVAC ($(echo "$java_files" | wc -l) source files)"
                mkdir -p "$java_inst_dir"
                if $JAVAC -d "$java_inst_dir" $java_files >> "$compile_log" 2>&1; then
                    (cd "$java_inst_dir" && $JAR cf "${PKG_NAME}.jar" *.class */*.class 2>/dev/null) || true
                    echo "    Java compilation OK"
                    has_java=true
                else
                    echo "    Java compilation FAILED (non-fatal)"
                fi
            fi
        fi

        # Link shared library
        if $compile_ok; then
            if [ -n "$OBJECTS" ]; then
                all_objs=""
                for obj in $OBJECTS; do
                    obj_path="$BUILD_TMP/$obj"
                    if [ ! -f "$obj_path" ]; then
                        obj_path=$(find "$SRC_DIR" -name "$obj" 2>/dev/null | head -1)
                    fi
                    all_objs="$all_objs $obj_path"
                done
            fi

            echo "    LD $PKG_NAME.so"
            # Add -ljvm only if Java sources were compiled
            JVM_LIBS=""
            $has_java && JVM_LIBS="-L${JAVA_HOME}/lib/server -ljvm"

            # Filter PKG_LIBS: remove -l flags for libraries that don't exist
            # These are typically local static archives (like yajl's libstatyajl.a)
            # that the Makefile would build but our flat compilation already covers
            LDFLAGS_resolved="$PKG_LIBS"
            filtered_libs=""
            for lib in $PKG_LIBS; do
                case "$lib" in
                    -l*)
                        libname="${lib#-l}"
                        libfound=false
                        # Check all -L directories in PKG_LIBS
                        for ldflag in $PKG_LIBS; do
                            case "$ldflag" in
                                -L*)
                                    ldir="${ldflag#-L}"
                                    [ -f "$ldir/lib${libname}.a" ] && libfound=true
                                    [ -f "$ldir/lib${libname}.so" ] && libfound=true
                                    ;;
                            esac
                        done
                        # Also check system library paths
                        [ -f "/usr/lib/lib${libname}.a" ] && libfound=true
                        [ -f "$R_LIB/lib${libname}.a" ] && libfound=true
                        [ -f "$R_LIB/lib${libname}.so" ] && libfound=true
                        [ -f "$EXT_LD/lib${libname}.a" ] && libfound=true
                        [ -f "$EXT_LD/lib${libname}.so" ] && libfound=true
                        $libfound && filtered_libs="$filtered_libs $lib"
                        ;;
                    *)  filtered_libs="$filtered_libs $lib" ;;
                esac
            done

            if ! $CC -shared -fPIC -o "$LIBS_DIR/$PKG_NAME.so" $all_objs \
                 -L"$R_LIB" -lR $filtered_libs --sysroot="$SYSROOT" \
                 -Wl,--allow-multiple-definition \
                 -L"$R_LIB" -lmuslstubs $JVM_LIBS >> "$compile_log" 2>&1; then
                err=$(grep -E "error:|undefined reference" "$compile_log" | head -3)
                echo "    LINK FAILED: ${err:-see $compile_log}"
                compile_ok=false
            fi
        fi

        rm -rf "$BUILD_TMP"

        if $compile_ok; then
            so_size=$(ls -lh "$LIBS_DIR/$PKG_NAME.so" | awk '{print $5}')
            echo "    OK ($so_size)"
        else
            echo "    Compilation failed (see $compile_log)"
            echo "$PKG_NAME: FAILED" >> "$LOG_DIR/fail_summary.log"
        fi
    fi
fi

# ======== Step 8: Create lazy-load DB ========
echo "  Running makeLazyLoading..."
"$BUILD_DIR/bin/exec/R" --vanilla --no-save --no-restore -e \
  "library(tools); wd <- getwd(); setwd(\"$LIB_DEST/$PKG_NAME\"); tools:::makeLazyLoading(\"$PKG_NAME\", lib.loc = \"$LIB_DEST\", compress = FALSE); setwd(wd)" \
  2>&1 | grep -v "^sh:" | grep -v "Warning.*which" | grep -v "During startup" | grep -v "^>" | grep -v "^Type" | grep -v "^R is" | grep -v "^Natural" | grep -v "^Copyright" | grep -v "^Platform" | grep -v "^You are"

echo "  Package '$PKG_NAME' installed successfully."
echo "Done."
